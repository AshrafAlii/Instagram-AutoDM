{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/auth/(.*)", "dest": "backend/server.js" },
    { "src": "/webhook/(.*)", "dest": "backend/server.js" },
    { "src": "/webhook", "dest": "backend/server.js" },
    { "src": "/automation/(.*)", "dest": "backend/server.js" },
    { "src": "/logs/(.*)", "dest": "backend/server.js" },
    { "src": "/logs", "dest": "backend/server.js" },
    { "src": "/health", "dest": "backend/server.js" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html" }
    
  ]
}
